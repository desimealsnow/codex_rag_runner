#!/usr/bin/env python3
"""Block pushes to any GitHub remote other than desimealsnow/codex_rag_runner."""

from __future__ import annotations

import sys

ALLOWED_OWNER = "desimealsnow"
ALLOWED_REPO = "codex_rag_runner"
BLOCKED_OWNER = "rameshchandranerolu"


def main() -> int:
    remote_name = sys.argv[1] if len(sys.argv) > 1 else ""
    remote_url = sys.argv[2] if len(sys.argv) > 2 else ""

    if BLOCKED_OWNER in remote_url.lower():
        print(
            f"Push blocked: remote '{remote_name}' points at {BLOCKED_OWNER}.",
            file=sys.stderr,
        )
        print(
            f"This clone is configured for {ALLOWED_OWNER}/{ALLOWED_REPO} only.",
            file=sys.stderr,
        )
        return 1

    url_lower = remote_url.lower()
    if "github.com" in url_lower:
        if ALLOWED_OWNER not in url_lower or ALLOWED_REPO not in url_lower:
            print(
                f"Push blocked: GitHub pushes must target "
                f"{ALLOWED_OWNER}/{ALLOWED_REPO}.",
                file=sys.stderr,
            )
            print(f"Remote URL: {remote_url}", file=sys.stderr)
            return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
